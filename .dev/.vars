# ---------------------------------------------------------
# Cloudflare Pages Functions 环境变量配置参考
# 请将此文件复制并重命名为 .dev.vars，然后填入你的真实密钥。
# ---------------------------------------------------------

# 【必填】你的 Coze Personal Access Token
# 获取地址：https://www.coze.cn/open/oauth/pats
COZE_PAT=your_coze_pat_here

# 【选填】你的博客域名，用于防盗刷校验（本地开发时可留空）
MY_BLOG_DOMAIN=