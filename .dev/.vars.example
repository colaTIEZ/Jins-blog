# ---------------------------------------------------------
# Cloudflare Pages Functions 本地开发环境变量模板
# 复制本文件为 .dev/.vars，并填入真实密钥
# ---------------------------------------------------------

# 【必填】Coze Personal Access Token
# 获取地址：https://www.coze.cn/open/oauth/pats
COZE_PAT=your_coze_pat_here

# 【选填】允许访问 /api/coze/token 的域名白名单
# 本地开发可留空
MY_BLOG_DOMAIN=
