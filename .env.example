# Coze WebSDK 前端公开配置（可公开）
# 从 Coze 项目地址或嵌入代码中获取 Project ID
PUBLIC_COZE_PROJECT_ID=your_project_id_here

# 服务端密钥（不要公开，不要提交真实值）
# Coze Personal Access Token (PAT)
COZE_PAT=your_coze_pat_token_here

# 允许访问 token 接口的站点域名（可选）
# 支持逗号分隔多个域名，例如：blog.example.com,preview.example.pages.dev
MY_BLOG_DOMAIN=yourdomain.com
